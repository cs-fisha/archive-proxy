# Local key clients use when calling the proxy/LiteLLM.
LITELLM_MASTER_KEY=sk-change-me-local-master-key

# API key for your upstream OpenAI / Anthropic compatible gateway.
UPSTREAM_API_KEY=sk-change-me-upstream-api-key

# OpenAI-compatible base URL. Usually ends with /v1.
UPSTREAM_OPENAI_BASE=https://your-new-api.example.com/v1

# Anthropic-compatible base URL. Usually does not end with /v1.
UPSTREAM_ANTHROPIC_BASE=https://your-new-api.example.com
