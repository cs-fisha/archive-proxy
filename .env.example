# archive-proxy only talks to LiteLLM. In Docker Compose, keep this value.
UPSTREAM_BASE_URL=http://litellm:4000

# Container path mounted from ./archives by docker-compose.yml.
ARCHIVE_ROOT=/data/archive

# Used when the proxy cannot infer openai/anthropic from path, headers, or model.
DEFAULT_FAMILY=openai

# Non-streaming bodies larger than this are stored as metadata only.
ARCHIVE_MAX_INLINE_BODY_BYTES=52428800

# Add x-archive-request-id to requests sent to LiteLLM.
ARCHIVE_ADD_REQUEST_ID_HEADER=false

# 0 means no total forwarding timeout.
ARCHIVE_FORWARD_TIMEOUT_SECONDS=0

# Recommended for any shared or production archive.
ARCHIVE_REDACT_HEADERS=true
