# archive-proxy only talks to LiteLLM. In Docker Compose, keep this value.
UPSTREAM_BASE_URL=http://litellm:4000

# Container path mounted from ./archives by docker-compose.yml.
ARCHIVE_ROOT=/data/archive

# Used when the proxy cannot infer openai/anthropic from path, headers, or model.
DEFAULT_FAMILY=openai

# Non-streaming bodies larger than this are stored as metadata only.
ARCHIVE_MAX_INLINE_BODY_BYTES=52428800

# Add x-archive-request-id to requests sent to LiteLLM.
ARCHIVE_ADD_REQUEST_ID_HEADER=false

# 0 means no total forwarding timeout.
ARCHIVE_FORWARD_TIMEOUT_SECONDS=0

# Recommended for any shared or production archive.
ARCHIVE_REDACT_HEADERS=true

# Streaming archive writes are buffered to reduce per-token latency.
ARCHIVE_STREAM_FLUSH_CHUNKS=32
ARCHIVE_STREAM_FLUSH_BYTES=262144

# Wait this many seconds for background archive writes during normal shutdown.
ARCHIVE_SHUTDOWN_DRAIN_SECONDS=5

# Bounded background archive queue. At full queue, best-effort response body archives
# may be dropped to protect request latency; critical error records write inline.
ARCHIVE_QUEUE_MAXSIZE=20000
ARCHIVE_WRITER_WORKERS=4

# worker writes index.<pid>.jsonl files, which is safer with multiple uvicorn workers.
# Use shared only if you intentionally want the old single index.jsonl behavior.
ARCHIVE_INDEX_MODE=worker
